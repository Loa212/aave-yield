{
  "name": "aave-yield",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5174",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit -p api/tsconfig.json",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "ci": "bun run lint && bun run typecheck && bun run typecheck:api && vite build",
    "webhook:register": "bun scripts/register-webhook.ts",
    "webhook:info": "bun scripts/register-webhook.ts --info",
    "webhook:delete": "bun scripts/register-webhook.ts --delete"
  },
  "dependencies": {
    "@bgd-labs/aave-address-book": "4.44.22",
    "@dynamic-labs/ethereum": "4.88.1",
    "@dynamic-labs/sdk-react-core": "4.88.1",
    "@dynamic-labs/ton": "4.88.1",
    "@dynamic-labs/utils": "4.88.1",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-slot": "1.2.4",
    "@ston-fi/omniston-sdk": "0.8.3",
    "@ston-fi/omniston-sdk-react": "0.8.3",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.11",
    "@telegram-apps/sdk-react": "3.3.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.17.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "3.5.0",
    "viem": "2.47.10"
  },
  "overrides": {
    "@tanstack/react-query": "5.101.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/router-plugin": "1.168.14",
    "@types/node": "22.13.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "tailwindcss": "4.3.0",
    "typescript": "5.7.3",
    "vite": "6.1.0",
    "vite-plugin-node-polyfills": "0.23.0"
  }
