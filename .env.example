# --- Client (inlined into the bundle by Vite at BUILD time; must start with VITE_) ---

# Dynamic environment ID — from app.dynamic.xyz dashboard.
# Set the real value in Vercel project env vars (scoped to Production) and in
# a local .env.local. Changing it requires a cacheless redeploy.
VITE_DYNAMIC_ENVIRONMENT_ID=

# --- Server (used only by api/bot.ts — the Telegram auth webhook. NOT VITE_-prefixed,
#     so these never reach the browser bundle.) ---

# BotFather bot token. The webhook signs the telegramAuthToken with this, and
# Dynamic verifies it with the SAME token (paste it in the Dynamic dashboard too).
TELEGRAM_BOT_TOKEN=

# Where the Mini App is hosted, e.g. https://aave-yield-chi.vercel.app
# Optional — api/bot.ts defaults to the known prod URL if unset. Override for
# preview deploys or a custom domain.
LOGIN_URL=
