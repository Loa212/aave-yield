{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/tonbridge/:path*",
      "destination": "/api/tonbridge"
    },
    {
      "source": "/((?!api|assets|favicon|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
