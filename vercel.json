{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/_tonbridge/:path*",
      "destination": "https://walletbot.me/tonconnect-bridge/bridge/:path*"
    },
    {
      "source": "/((?!api|assets|favicon|_tonbridge|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
